{
  "expo": {
    "name": "Wuxi Weekend",
    "slug": "wuxi-weekend-planner",
    "scheme": "wuxiweekend",
    "version": "0.2.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#fdf6f0",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.wuxiweekend.app",
      "infoPlist": {
        "LSApplicationQueriesSchemes": ["iosamap", "baidumap", "weixin"]
      }
    },
    "android": {
      "package": "com.wuxiweekend.app",
      "adaptiveIcon": {
        "backgroundColor": "#fdf6f0"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": ["expo-router"],
    "extra": {
      "supabaseUrl": null,
      "supabaseAnonKey": null
    }
  }
}
