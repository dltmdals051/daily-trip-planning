{
  "expo": {
    "name": "Wuxi Weekend",
    "slug": "wuxi-weekend-planner",
    "scheme": "wuxiweekend",
    "version": "0.2.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "backgroundColor": "#fdf6f0",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.wuxiweekend.app",
      "buildNumber": "1",
      "icon": "./assets/icon.png",
      "infoPlist": {
        "LSApplicationQueriesSchemes": ["iosamap", "baidumap", "weixin"],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.wuxiweekend.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#fdf6f0"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": ["expo-router"],
    "experiments": {
      "baseUrl": "/daily-trip-planning"
    },
    "extra": {
      "supabaseUrl": null,
      "supabaseAnonKey": null,
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": ""
      }
    }
  }
}
