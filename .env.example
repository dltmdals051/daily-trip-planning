# Expo 앱이 사용 (클라이언트에 노출됨)
EXPO_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJxxx...

# 스크립트(generate-live, seed) + Edge Function 에서만 사용
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJxxx...

# Gemini API — 서버 사이드에서만 사용 (cron + Supabase Edge Function)
# Edge Function 에 등록: Supabase Dashboard → Project Settings → Edge Functions → Secrets
GEMINI_API_KEY=AIzaSy...
